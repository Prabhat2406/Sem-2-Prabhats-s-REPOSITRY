<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FitLife</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="style.css">
</head>

<body>

    <nav class="bg-gray-800 text-white p-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">

            <h1 class="text-2xl font-bold">FitLife</h1>

            <ul class="hidden md:flex gap-6">
                <li><a href="#">Home</a></li>
                <li><a href="#">Programs</a></li>
                <li><a href="#">Trainers</a></li>
                <li><a href="#">Contact</a></li>
            </ul>

        </div>
    </nav>

    <section class="bg-gradient-to-r from-blue-200 to-indigo-400 text-center py-16 px-4">

        <h2 class="text-3xl md:text-5xl font-bold text-white">
            Transform Your Body & Mind
        </h2>

        <p class="text-white mt-4 text-sm md:text-lg">
            Join FitLife today and achieve your fitness goals.
        </p>

        <button id="joinBtn"
            class="mt-6 bg-white text-black px-6 py-2 rounded shadow hover:bg-gray-200">
            Join Now
        </button>

    </section>

    <section class="py-12 px-4">

        <h2 class="text-3xl font-bold text-center mb-10">
            Our Programs
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto">

            <div class="bg-white p-6 rounded-lg shadow text-center">
                <h3 class="text-xl font-bold text-red-500 mb-3">
                    Weight Training
                </h3>

                <p>
                    Build strength and muscle with guided programs.
                </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow text-center">
                <h3 class="text-xl font-bold text-red-500 mb-3">
                    Yoga Classes
                </h3>

                <p>
                    Improve flexibility and wellness through yoga.
                </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow text-center">
                <h3 class="text-xl font-bold text-red-500 mb-3">
                    Diet Plans
                </h3>

                <p>
                    Personalized diet plans for your fitness routine.
                </p>
            </div>

        </div>

    </section>

    <footer class="bg-gradient-to-r from-blue-200 to-indigo-400 text-white text-center py-6">
        <p>© 2026 FitLife | All Rights Reserved</p>
        <p class="mt-2">Contact: info@fitlife.com</p>
    </footer>

    <script src="script.js"></script>

</body>
</html>
